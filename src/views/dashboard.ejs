<!DOCTYPE html>
<html lang="lt">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <main class="app-shell">
    <div class="container container-narrow">
      <header class="page-header">
        <div class="brand-block">
          <div class="brand-mark">K</div>
          <div>
            <h1 class="brand-title">Kaukių pridėjimas</h1>
            <p class="brand-subtitle">Dovanų kaukių pridėjimas užsakymams</p>
          </div>
        </div>

        <div class="topbar-right">
          <% if (currentUser) { %>
            <div class="user-chip"><%= currentUser.username %></div>
          <% } %>

          <nav class="nav">
            <a href="/settings">Nustatymai</a>
            <a href="/logout">Atsijungti</a>
          </nav>
        </div>
      </header>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>

      <section class="surface">
        <div class="surface-inner">
          <div class="section-head">
            <div>
              <h2>Užsakymų apdorojimas</h2>
              <p class="muted">
                Patikrinkite likutį be pakeitimų arba pridėkite kaukes visiems neįvykdytiems užsakymams.
              </p>
            </div>
          </div>

          <div class="run-controls">
            <div class="limit-field">
              <label class="form-label" for="run-limit">Limitas (nebūtina)</label>
              <input class="form-control" type="number" id="run-limit" min="1" placeholder="Pvz.: 20" />
            </div>

            <div class="run-buttons">
              <button type="button" class="button button-secondary" id="btn-dry-all">
                Tikrinti likutį
              </button>
              <button type="button" class="button button-primary" id="btn-apply-all">
                Pridėti kaukes
              </button>
            </div>
          </div>
        </div>
      </section>

      <section class="surface progress-surface" id="progress-card" hidden>
        <div class="surface-inner">
          <div class="progress-head">
            <h2 id="progress-title">Vykdoma</h2>
            <span class="progress-phase" id="progress-phase">Pradedama…</span>
          </div>

          <div class="progress-bar" aria-hidden="true">
            <div class="progress-bar-fill" id="progress-fill" style="width: 0%"></div>
          </div>

          <div class="progress-meta">
            <span id="progress-counts">0 / 0 užsakymų</span>
            <span id="progress-current" class="muted"></span>
          </div>

          <div class="progress-stats">
            <div class="progress-stat">
              <div class="progress-stat-label">Pridėta</div>
              <div class="progress-stat-value progress-applied" id="stat-applied">0</div>
            </div>
            <div class="progress-stat">
              <div class="progress-stat-label">Praleista</div>
              <div class="progress-stat-value progress-skipped" id="stat-skipped">0</div>
            </div>
            <div class="progress-stat">
              <div class="progress-stat-label">Klaidų</div>
              <div class="progress-stat-value progress-failed" id="stat-failed">0</div>
            </div>
            <div class="progress-stat">
              <div class="progress-stat-label">Gauta</div>
              <div class="progress-stat-value" id="stat-fetched">0</div>
            </div>
          </div>

          <div class="progress-message" id="progress-message" hidden></div>

          <div class="results-wrap" id="results-wrap" hidden>
            <div class="data-table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Užsakymas</th>
                    <th>Suma</th>
                    <th>Pakopa</th>
                    <th>SKU</th>
                    <th>Būsena</th>
                    <th>Priežastis</th>
                  </tr>
                </thead>
                <tbody id="results-body"></tbody>
              </table>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>

  <script>
    (function () {
      const dryBtn = document.getElementById("btn-dry-all");
      const applyBtn = document.getElementById("btn-apply-all");
      const limitInput = document.getElementById("run-limit");

      const card = document.getElementById("progress-card");
      const titleEl = document.getElementById("progress-title");
      const phaseEl = document.getElementById("progress-phase");
      const fillEl = document.getElementById("progress-fill");
      const countsEl = document.getElementById("progress-counts");
      const currentEl = document.getElementById("progress-current");
      const messageEl = document.getElementById("progress-message");
      const appliedEl = document.getElementById("stat-applied");
      const skippedEl = document.getElementById("stat-skipped");
      const failedEl = document.getElementById("stat-failed");
      const fetchedEl = document.getElementById("stat-fetched");
      const resultsWrap = document.getElementById("results-wrap");
      const resultsBody = document.getElementById("results-body");

      const PHASE_LABELS = {
        queued: "Eilėje",
        auth: "Jungiamasi prie Shopify…",
        "loading-variants": "Įkeliamos dovanų prekės…",
        "fetching-orders": "Gaunami užsakymai…",
        planning: "Planuojama…",
        applying: "Pridedamos kaukės…",
        done: "Baigta",
        error: "Klaida",
      };

      const STATUS_LABELS = {
        applied: "pridėta",
        planned: "suplanuota",
        skipped: "praleista",
        failed: "klaida",
      };

      function escapeHtml(value) {
        return String(value == null ? "" : value)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#39;");
      }

      function setRunning(disabled) {
        dryBtn.disabled = disabled;
        applyBtn.disabled = disabled;
        limitInput.disabled = disabled;
      }

      function showMessage(text, kind) {
        messageEl.textContent = text;
        messageEl.className = "progress-message" + (kind ? " progress-message-" + kind : "");
        messageEl.hidden = !text;
      }

      function renderResults(rows) {
        if (!rows || rows.length === 0) {
          resultsWrap.hidden = true;
          resultsBody.innerHTML = "";
          return;
        }

        resultsBody.innerHTML = rows
          .map((row) => {
            const status = row.status || "";
            const statusLabel = STATUS_LABELS[status] || status;
            return (
              "<tr>" +
              "<td>" + escapeHtml(row.orderName) + "</td>" +
              "<td>" + escapeHtml(row.subtotal || "-") + "</td>" +
              "<td>" + escapeHtml(row.plannedTier || "-") + "</td>" +
              "<td>" + escapeHtml(row.plannedSku || "-") + "</td>" +
              "<td><span class='status-badge status-" + escapeHtml(status) + "'>" + escapeHtml(statusLabel) + "</span></td>" +
              "<td>" + escapeHtml(row.reason) + "</td>" +
              "</tr>"
            );
          })
          .join("");

        resultsWrap.hidden = false;
      }

      function updateProgress(job) {
        phaseEl.textContent = PHASE_LABELS[job.phase] || job.phase || "";

        const total = job.total || 0;
        const processed = job.processed || 0;
        const pct = total > 0 ? Math.min(100, Math.round((processed / total) * 100)) : 0;

        fillEl.style.width = pct + "%";

        if (total > 0) {
          countsEl.textContent = processed + " / " + total + " užsakymų (" + pct + "%)";
        } else if (job.fetched > 0) {
          countsEl.textContent = "Gauta " + job.fetched + " užsakymų…";
        } else {
          countsEl.textContent = "Dirbama…";
        }

        currentEl.textContent = job.currentOrder ? "Paskutinis: " + job.currentOrder : "";
        appliedEl.textContent = job.applied || 0;
        skippedEl.textContent = job.skipped || 0;
        failedEl.textContent = job.failed || 0;
        fetchedEl.textContent = job.fetched || job.total || 0;
      }

      async function pollJob(jobId) {
        const response = await fetch("/run/jobs/" + encodeURIComponent(jobId), {
          headers: { Accept: "application/json" },
        });

        if (!response.ok) {
          throw new Error("Nepavyko gauti būsenos: " + response.status);
        }

        return response.json();
      }

      async function runJob(apply) {
        setRunning(true);
        showMessage("", null);
        renderResults([]);

        card.hidden = false;
        titleEl.textContent = apply ? "Kaukių pridėjimas" : "Likučio tikrinimas";
        phaseEl.textContent = "Pradedama…";
        fillEl.style.width = "0%";
        countsEl.textContent = "0 / 0 užsakymų";
        currentEl.textContent = "";
        appliedEl.textContent = "0";
        skippedEl.textContent = "0";
        failedEl.textContent = "0";
        fetchedEl.textContent = "0";
        card.scrollIntoView({ behavior: "smooth", block: "nearest" });

        let jobId;

        try {
          const startResponse = await fetch("/run/all/start", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Accept: "application/json",
            },
            body: JSON.stringify({
              apply: apply,
              limit: limitInput.value || null,
            }),
          });

          if (!startResponse.ok) {
            const err = await startResponse.json().catch(() => ({}));
            throw new Error(err.error || ("Nepavyko pradėti: " + startResponse.status));
          }

          const startJson = await startResponse.json();
          jobId = startJson.jobId;
        } catch (error) {
          showMessage(error.message, "error");
          setRunning(false);
          return;
        }

        // Poll until done.
        while (true) {
          await new Promise((r) => setTimeout(r, 800));

          let job;
          try {
            job = await pollJob(jobId);
          } catch (error) {
            showMessage(error.message, "error");
            setRunning(false);
            return;
          }

          updateProgress(job);

          if (job.state === "done") {
            const summary =
              "Baigta. Pridėta " + (job.applied || 0) +
              ", praleista " + (job.skipped || 0) +
              ", klaidų " + (job.failed || 0) +
              " iš " + (job.total || 0) + " užsakymų.";
            showMessage(summary, "success");
            renderResults(job.results || []);
            setRunning(false);
            return;
          }

          if (job.state === "error") {
            showMessage(job.error || "Vykdymas nepavyko.", "error");
            setRunning(false);
            return;
          }
        }
      }

      dryBtn.addEventListener("click", () => runJob(false));
      applyBtn.addEventListener("click", () => {
        if (!confirm("Pridėti kaukes visiems tinkamiems neįvykdytiems užsakymams?")) return;
        runJob(true);
      });
    })();
  </script>
</body>
</html>
