<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <main class="app-shell">
    <div class="container">
      <header class="page-header">
        <div class="brand-block">
          <div class="brand-mark">K</div>
          <div>
            <h1 class="brand-title">Kaukių pridėjimas</h1>
            <p class="brand-subtitle">Settings and SKU priority management</p>
          </div>
        </div>

        <div class="topbar-right">
          <% if (currentUser) { %>
            <div class="user-chip"><%= currentUser.username %></div>
          <% } %>

          <nav class="nav">
            <a href="/">Dashboard</a>
            <a href="/settings">Settings</a>
            <a href="/runs">Runs</a>
            <a href="/logout">Logout</a>
          </nav>
        </div>
      </header>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>

      <section class="surface">
        <div class="surface-inner">
          <div class="section-head">
            <div>
              <h2>Automation settings</h2>
              <p class="muted">Adjust reason text, schedule, timezone, and SKU priority.</p>
            </div>
          </div>

          <form method="post" action="/settings" class="form-stack">
            <div class="form-grid">
              <div>
                <label class="form-label">Gift reason</label>
                <input class="form-control" type="text" name="reasonText" value="<%= settings.reasonText %>" required />
              </div>

              <div>
                <label class="form-label">Timezone</label>
                <input class="form-control" type="text" name="timezone" value="<%= settings.timezone %>" required />
              </div>

              <div>
                <label class="form-label">Schedule hour (0-23)</label>
                <input class="form-control" type="number" name="scheduleHour" min="0" max="23" value="<%= settings.scheduleHour %>" required />
              </div>

              <div>
                <label class="form-label">Schedule minute (0-59)</label>
                <input class="form-control" type="number" name="scheduleMinute" min="0" max="59" value="<%= settings.scheduleMinute %>" required />
              </div>
            </div>

            <label class="checkbox-row">
              <input type="checkbox" name="scheduleEnabled" <%= settings.scheduleEnabled ? "checked" : "" %> />
              Enable daily schedule
            </label>

            <section class="card">
              <h3>Tier SKU priority</h3>
              <p class="muted">
                Separate SKUs with commas. The first SKU is tried first, then the next SKU becomes fallback.
              </p>

              <div class="form-stack">
                <% settings.giftRules.forEach(rule => { %>
                  <div>
                    <label class="form-label"><%= rule.label %></label>
                    <input
                      class="form-control"
                      type="text"
                      name="giftRule_<%= rule.tier %>"
                      value="<%= rule.skus.join(', ') %>"
                      required
                    />
                    <div class="form-help">
                      Fixed price band:
                      <% if (rule.maxExclusive == null) { %>
                        €<%= rule.min %>+
                      <% } else { %>
                        €<%= rule.min %> to &lt; €<%= rule.maxExclusive %>
                      <% } %>
                    </div>
                  </div>
                <% }) %>
              </div>
            </section>

            <div class="button-row">
              <button type="submit" class="button button-primary">Save settings</button>
              <a href="/" class="button button-ghost">Back to dashboard</a>
            </div>
          </form>
        </div>
      </section>
    </div>
  </main>
</body>
</html>