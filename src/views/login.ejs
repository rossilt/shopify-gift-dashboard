<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <main class="auth-shell">
    <section class="auth-card">
      <div class="brand-pill">Shopify Automatika</div>
      <h1 class="auth-title">Kaukių pridėjimas</h1>
      <p class="auth-subtitle">
        Prisijunkite, kad galėtumėte tikrinti likutį, pridėti kaukes ir tvarkyti nustatymus.
      </p>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form method="post" action="/login" class="form-stack">
        <div>
          <label class="form-label" for="username">Vartotojo vardas</label>
          <input class="form-control" id="username" type="text" name="username" required />
        </div>

        <div>
          <label class="form-label" for="password">Slaptažodis</label>
          <input class="form-control" id="password" type="password" name="password" required />
        </div>

        <button type="submit" class="button button-primary">Prisijungti</button>
      </form>
    </section>
  </main>
</body>
</html>